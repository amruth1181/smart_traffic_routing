# ------------------------------------------------------------------
# Copy this file to `.env` and adjust values.  Never commit `.env`.
# ------------------------------------------------------------------

# ---- Warehouse (Postgres) ----
# Local dev = the `warehouse` service in docker-compose.
# Cloud = point these at Cloud SQL / RDS / a managed Postgres endpoint.
WAREHOUSE_HOST=localhost
WAREHOUSE_PORT=5432
WAREHOUSE_DB=traffic_warehouse
WAREHOUSE_USER=traffic
WAREHOUSE_PASSWORD=traffic
WAREHOUSE_RAW_SCHEMA=raw

# ---- MongoDB (source of the enriched streaming records) ----
MONGO_URI=mongodb://127.0.0.1:27017/
MONGO_DB=smart_traffic_db
MONGO_COLLECTION=traffic_weather_incidents

# ---- dbt ----
# Tells dbt to read the profiles.yml that ships inside this repo's ./dbt folder.
DBT_PROFILES_DIR=./dbt

# ---- Alerting (optional) ----
# If set, pipeline failures in Airflow post a message to this Slack webhook.
SLACK_WEBHOOK_URL=

# ---- Project root (used by the Airflow DAG) ----
SMART_TRAFFIC_HOME=/absolute/path/to/smart_traffic_routing
